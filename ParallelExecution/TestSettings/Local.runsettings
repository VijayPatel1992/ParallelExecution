<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Number of threads (usually = CPU cores) -->
    <MaxCpuCount>4</MaxCpuCount>
  </RunConfiguration>
  <MSTest>
    <Parallelize>
      <!-- Number of parallel workers -->
      <Workers>4</Workers>
      <!-- Scope: ClassLevel or MethodLevel -->
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>
</RunSettings>
